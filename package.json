{
  "name": "impossible-battlegrounds",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Browser-based deterministic 3D sandbox auto-battler.",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "build:pages": "VITE_BASE_PATH=/impossible-battlegrounds/ npm run build",
    "preview": "vite preview --host 127.0.0.1",
    "audit": "npm audit --audit-level=high",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:webkit": "playwright test --project=webkit",
    "validate:pages": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run test:e2e:chromium && npm run build:pages",
    "validate": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run test:e2e && npm run build:pages",
    "perf:sample": "tsx scripts/performanceSample.ts"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@vitejs/plugin-react": "6.0.2",
    "lucide-react": "1.21.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "0.184.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.184.1",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.6.0",
    "jsdom": "29.1.1",
    "prettier": "3.8.4",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24.0.0"
  }
}
